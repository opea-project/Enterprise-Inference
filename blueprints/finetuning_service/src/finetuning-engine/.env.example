# Application Environment
ENV=production
APP_NAME="GPU Accelerated Fine-tuning Engine"
LOG_LEVEL=INFO

# Keycloak Configuration
# KEYCLOAK_ISSUER: Full issuer URL including realm, e.g. https://keycloak.example.com/realms/myrealm
KEYCLOAK_ISSUER="https://keycloak.example.com/realms/myrealm"
# KEYCLOAK_AUDIENCE: The client-id that must match the 'azp' claim in the JWT
KEYCLOAK_AUDIENCE="finetuning-api"
# KEYCLOAK_INTERNAL_URL (optional): Internal URL used only for JWKS fetch inside Docker
# Set this when the external KEYCLOAK_ISSUER hostname is not reachable from inside the container
# Example: KEYCLOAK_INTERNAL_URL="https://keycloak:8443/realms/myrealm"
KEYCLOAK_INTERNAL_URL=""

# CORS Configuration
# Comma-separated list of allowed origins. NEVER use "*" in production.
ALLOWED_ORIGINS="https://your-frontend.example.com,http://localhost:3000"

# Database Configuration
# PostgreSQL credentials (used by docker-compose and app)
POSTGRES_USER="finetune"
POSTGRES_PASSWORD="<your_secure_password_here>"
POSTGRES_DB="finetune_db"

# Full connection string (auto-constructed from above)
# For container-to-container: use @postgres:5432
# For host-to-container: use @localhost:5432
DATABASE_URL="postgresql+asyncpg://finetune:<your_secure_password_here>@postgres:5432/finetune_db"

# File Service Integration (user UUID will be used for auth)
FILES_API_URL="Files API Endpoint URL here"

# Storage Paths Inside container
TEMP_DATA_DIR="/tmp/finetune_data"
MODEL_OUTPUT_DIR="/tmp/finetune_models"
LOG_DIR="/tmp/finetune_logs"

# GPU & Training Configuration
MAX_CONCURRENT_JOBS=1
GPU_MEMORY_THRESHOLD_GB=1.0
DEFAULT_MAX_SEQ_LENGTH=2048
DEFAULT_BATCH_SIZE=2
DEFAULT_GRADIENT_ACCUMULATION=8
