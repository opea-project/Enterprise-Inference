# ============================================
# Fine-Tuning API Configuration Template
# ============================================
#
# DON'T EDIT THIS FILE!
#
# Instead, run the setup script:
#   ./scripts/setup.sh
#
# The setup script will:
#   - Auto-generate secure password for PostgreSQL
#   - Ask you for only the essential information (Training Backend, Domain)
#   - Create a ready-to-use .env file
#
# If you prefer to configure manually, copy this file to .env
# and fill in all the values below.
# ============================================

# ============================================
# REQUIRED: Training Backend (Nvidia/Unsloth)
# ============================================
# The URL for your training backend service
NVIDIA_API_URL=https://your-training-backend.example.com:8443

# Nvidia Backend API Timeout (seconds)
NVIDIA_API_TIMEOUT=120

# Maximum concurrent jobs allowed
NVIDIA_MAX_JOBS=1

# ============================================
# REQUIRED: Keycloak OAuth2 Configuration
# ============================================
# Keycloak configuration for authenticating with Nvidia backend
# Uses OAuth2 client credentials flow

# Keycloak token endpoint URL
# Format: https://<keycloak-domain>/realms/<realm-name>/protocol/openid-connect/token
NVIDIA_KEYCLOAK_TOKEN_URL=https://keycloak.example.com/realms/your-realm/protocol/openid-connect/token

# OAuth2 Client ID for Nvidia backend authentication
NVIDIA_KEYCLOAK_CLIENT_ID=nvidia-backend-client

# OAuth2 Client Secret for Nvidia backend authentication
NVIDIA_KEYCLOAK_CLIENT_SECRET=your-client-secret-here

# Whether to verify SSL certificates when calling Keycloak (true/false)
# Set to false only in development with self-signed certificates
NVIDIA_KEYCLOAK_VERIFY_SSL=true

# ============================================
# REQUIRED: Domain Configuration
# ============================================
# Your domain name (API will be at: https://finetune-api-YOUR_DOMAIN)
BASE_DOMAIN=example.com

# ============================================
# REQUIRED: TLS Certificates Path
# ============================================
# Path to the directory containing TLS certificates
# Required files: tls.crt and tls.key
CERTS_PATH=/home/ubuntu/certs

# ============================================
# OPTIONAL: Additional Configuration
# ============================================

# Kubernetes Namespace
NAMESPACE=finetuning

# Dataprep API (if you have a separate dataprep service)
DATAPREP_API_URL=

# ============================================
# AUTO-GENERATED BY SETUP SCRIPT
# (You can also generate these manually if needed)
# ============================================

# Database Configuration (will be auto-generated)
# Generate password: openssl rand -base64 32
DATABASE_URL=postgresql://finetuning:AUTO_GENERATED_PASSWORD@finetuning-service-postgresql:5432/finetuning
POSTGRES_PASSWORD=AUTO_GENERATED_PASSWORD

# ============================================
# ADVANCED OPTIONS (Usually don't need to change)
# ============================================

# Database Connection Pool
DB_POOL_MIN_SIZE=5
DB_POOL_MAX_SIZE=20

# Training Backend Timeout
NVIDIA_API_TIMEOUT=120
NVIDIA_MAX_JOBS=1

# Server Configuration
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
LOG_LEVEL=INFO

# ============================================
# RATE LIMITING CONFIGURATION
# ============================================
# Enable/disable rate limiting globally
RATE_LIMIT_ENABLED=true

# Default rate limit for all endpoints (requests per minute)
RATE_LIMIT_DEFAULT=200

# Health check endpoints (lightweight operations)
RATE_LIMIT_HEALTH=100

# Model list/retrieve endpoints (read operations)
RATE_LIMIT_MODELS=100

# Job creation endpoint (resource-intensive)
RATE_LIMIT_JOB_CREATE=10

# Job listing/retrieve endpoints
RATE_LIMIT_JOB_READ=60

# Job cancellation endpoint
RATE_LIMIT_JOB_CANCEL=20

# Job events endpoint
RATE_LIMIT_JOB_EVENTS=60

# ============================================
# CORS CONFIGURATION
# ============================================
# Allowed origins for CORS requests
# The setup script will auto-populate this with: ["https://YOUR_DOMAIN"]
#
# Development (local testing):
# API_CORS_ORIGINS=["http://localhost:3000","http://localhost:8080"]
#
# Production (single domain):
# API_CORS_ORIGINS=["https://app.example.com"]
#
# Production (multiple domains):
# API_CORS_ORIGINS=["https://app.example.com","https://admin.example.com","https://portal.example.com"]
#
# Note: For security, wildcards are not allowed. Each origin must be explicitly listed.
# CORS headers (Authorization, Content-Type, ft-api-key, etc.) are hardcoded in config.py
# and cannot be overridden via environment variables to prevent security misconfigurations.

# Image Tag (for deployment)
IMAGE_TAG=latest
